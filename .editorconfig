# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# 后端：Laravel / Pint 默认 4 空格
[*.{php,blade.php}]
indent_size = 4

# 前端：Vite + Vue 默认 2 空格
[*.{js,ts,jsx,tsx,vue,css,scss,html,json,jsonc,yml,yaml}]
indent_size = 2

# Makefile 必须用 Tab
[Makefile]
indent_style = tab

# Markdown：保留行尾空格（两个空格 = 换行）
[*.md]
trim_trailing_whitespace = false
